{
  "name": "@unequal/local-llm",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./config": {
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./provider": {
      "import": "./dist/provider.js",
      "default": "./dist/provider.js"
    },
    "./local-embedder": {
      "import": "./dist/local-embedder.js",
      "default": "./dist/local-embedder.js"
    },
    "./cloud-embedder": {
      "import": "./dist/cloud-embedder.js",
      "default": "./dist/cloud-embedder.js"
    },
    "./local-chat": {
      "import": "./dist/local-chat.js",
      "default": "./dist/local-chat.js"
    },
    "./cloud-chat": {
      "import": "./dist/cloud-chat.js",
      "default": "./dist/cloud-chat.js"
    },
    "./status-store": {
      "import": "./dist/status-store.js",
      "default": "./dist/status-store.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "openai": "^6.44.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "allowedBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
