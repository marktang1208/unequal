# unequal Oracle 2.0 部署环境变量模板
# 复制为 .env 后填入真实值（.env 不入 git）

# ============ 必填 secrets (4) ============
# 用 openssl rand -hex 32 生成
ADMIN_TOKEN=__GENERATE_ADMIN_TOKEN__
JWT_SECRET=__GENERATE_JWT_SECRET__
KEK_SECRET_V1=__GENERATE_KEK_SECRET__

# 保持 CloudBase 现有值（迁移后用不上，但 P8 pg 模式仍可从 CloudBase 拉向量）
MINIMAX_API_KEY=__YOUR_MINIMAX_API_KEY__

# ============ 必填 vars (5) ============
ENVIRONMENT=production
ALLOWED_ORIGIN=https://__YOUR_DOMAIN__
KEK_CURRENT_VERSION=1
DEFAULT_USER_ID=01H0000000000000000000000
VECTOR_STORE=pg

# PG 连接串（容器内部用 service name "pg"）
PG_CONNECTION_STRING=postgresql://unequal:${POSTGRES_PASSWORD}@pg:5432/unequal

# ============ 推荐配置 ============
LLM_MODEL=MiniMax-Text-01
EMBED_MODEL=embo-01
LLM_MAX_TOKENS=2048
NLI_PROVIDER=onnx
NLI_MODEL_LOCAL_PATH=/app/nli-assets/nli-MiniLM2-L6-H768-quint8_avx2.onnx
NLI_ASYNC=1

# 登录限流
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MS=900000

# ============ 微信小程序 (可选) ============
WX_APP_ID=wxf5b8ce05a977f0c6
WX_APP_SECRET=__YOUR_WX_APP_SECRET__

# ============ PG 容器配置 ============
POSTGRES_DB=unequal
POSTGRES_USER=unequal
POSTGRES_PASSWORD=__GENERATE_PG_PASSWORD__

# ============ 管理员 IP 白名单 ============
# 你的 Mac + 国内家宽（CIDR）
ADMIN_IP_ALLOWLIST=__YOUR_IP_CIDR__
