.citation-card {
  background: #eff6ff;
  border: 1rpx solid #93c5fd;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin: 12rpx 0;
}

.citation-card .header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.citation-card .num {
  font-family: ui-monospace, "SF Mono", Menlo, monospace;
  font-size: 24rpx;
  color: #1d4ed8;
  font-weight: 600;
  flex-shrink: 0;
}

.citation-card .title {
  font-size: 26rpx;
  color: #1e3a8a;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.citation-card .trust {
  font-size: 22rpx;
  color: #2563eb;
  background: #dbeafe;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.citation-card .snippet {
  font-size: 24rpx;
  color: #475569;
  line-height: 1.5;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
