/* CP-7-B round 8: 06 童心日历 — px 单位修描边渲染问题
 * 小程序 view 对 rpx 边框 < 2px 时可能被吃掉，改用 px 强制保留
 *
 * Design token：
 *   背景米黄 #fff9e6
 *   主深棕 #3d2914
 *   暖橙 #ff8a65
 *   橙黄 #ffb84d
 */

.bubble {
  max-width: 80%;
  padding: 22rpx 28rpx;
  margin: 22rpx 24rpx;
  word-break: break-word;
  box-sizing: border-box;
  position: relative;
}

/* user 气泡：橙黄 + 2px 深棕粗描边 + 6px 金黄偏移阴影 */
.bubble.user {
  align-self: flex-end;
  background: #ffb84d;
  color: #3d2914;
  border: 2px solid #3d2914;
  border-radius: 24rpx 8rpx 24rpx 24rpx;
  box-shadow: 6rpx 6rpx 0 0 #f5a623;
  font-weight: 600;
}

/* assistant 气泡：白卡 + 2px 深棕粗描边 + 6px 橙黄偏移阴影 */
.bubble.assistant {
  align-self: flex-start;
  background: #ffffff;
  color: #3d2914;
  border: 2px solid #3d2914;
  border-radius: 8rpx 24rpx 24rpx 24rpx;
  box-shadow: 6rpx 6rpx 0 0 #ffb84d;
  font-weight: 500;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  color: #3d2914;
}

/* cached tag */
.cached-tag {
  display: inline-block;
  margin-top: 14rpx;
  padding: 4rpx 18rpx;
  background: #a8c8a0;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  border: 1.5px solid #3d2914;
  border-radius: 100rpx;
  box-shadow: 3rpx 3rpx 0 0 #3d2914;
  letter-spacing: 0.3rpx;
}

.citations {
  margin-top: 18rpx;
}

/* [N] 圆形小徽章 */
.cite-num {
  display: inline-block;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  padding: 0 10rpx;
  margin: 0 4rpx;
  background: #ff8a65;
  color: #ffffff;
  font-weight: 800;
  font-size: 22rpx;
  text-align: center;
  border: 1.5px solid #3d2914;
  border-radius: 100rpx;
  box-shadow: 3rpx 3rpx 0 0 #3d2914;
  vertical-align: middle;
}

.cite-num:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 1rpx 1rpx 0 0 #3d2914;
}
