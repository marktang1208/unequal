/* CP-7-B round 7: 06 童心日历风格 — message-bubble
 * user 气泡：橙黄 #ffb84d + 粗描边 + 偏移阴影
 * assistant 气泡：白卡 + 粗描边 + 偏移橙阴影
 * [N] cite：圆形暖橙白字（小圆徽章）
 * cached tag：薄荷绿 + 粗描边
 *
 * 设计要点：圆角不对称（左上 vs 右上）+ 粗描边 + 阴影偏移 = 明信片
 */

.bubble {
  max-width: 80%;
  padding: 22rpx 28rpx;
  margin: 18rpx 24rpx;
  word-break: break-word;
  box-sizing: border-box;
  position: relative;
}

/* user 气泡：橙黄 + 粗描边 + 偏移阴影 */
.bubble.user {
  align-self: flex-end;
  background: #ffb84d;
  color: #3d2914;
  border: 3rpx solid #3d2914;
  /* 右下角小、其它大 → 明信片折角感 */
  border-radius: 24rpx 8rpx 24rpx 24rpx;
  box-shadow: 4rpx 4rpx 0 #f5a623;
  font-weight: 600;
}

/* assistant 气泡：白卡 + 粗描边 + 偏移橙阴影 */
.bubble.assistant {
  align-self: flex-start;
  background: #ffffff;
  color: #3d2914;
  border: 3rpx solid #3d2914;
  border-radius: 8rpx 24rpx 24rpx 24rpx;
  box-shadow: 4rpx 4rpx 0 #ffb84d;
  font-weight: 500;
}

.bubble-text {
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
}

/* cached tag：薄荷绿圆胶囊 + 粗描边 */
.cached-tag {
  display: inline-block;
  margin-top: 14rpx;
  padding: 4rpx 18rpx;
  background: #a8c8a0;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  border: 2rpx solid #3d2914;
  border-radius: 100rpx;
  box-shadow: 2rpx 2rpx 0 #3d2914;
  letter-spacing: 0.3rpx;
}

.citations {
  margin-top: 18rpx;
}

/* CP-7-B 富文本 cite-num：圆形小徽章 */
.cite-num {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  padding: 0 8rpx;
  margin: 0 4rpx;
  background: #ff8a65;
  color: #ffffff;
  font-weight: 800;
  font-size: 22rpx;
  text-align: center;
  border: 2rpx solid #3d2914;
  border-radius: 100rpx;
  box-shadow: 2rpx 2rpx 0 #3d2914;
  vertical-align: middle;
  transition: transform 0.1s ease, box-shadow 0.1s ease;
}

.cite-num:active {
  transform: translate(1rpx, 1rpx);
  box-shadow: 1rpx 1rpx 0 #3d2914;
}
