/* CP-7-B round 8: 06 童心日历 — history px 单位修描边
 */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #fff9e6;
  box-sizing: border-box;
  position: relative;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  background: transparent;
  border-bottom: none;
  position: relative;
  z-index: 1;
}

.header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #ff8a65;
  letter-spacing: -0.5rpx;
}

.loading,
.empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a89887;
  font-size: 28rpx;
  padding: 120rpx 0;
  position: relative;
  z-index: 1;
  font-weight: 600;
}

.error {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.error text {
  color: #d63a1a;
  font-size: 28rpx;
  text-align: center;
  font-weight: 600;
}

.session-list {
  padding: 16rpx 28rpx 120rpx;
  position: relative;
  z-index: 1;
}

/* 童趣卡片：2px 粗描边 + 6rpx 偏移阴影 */
.session {
  background: #ffffff;
  border: 2px solid #3d2914;
  border-radius: 8rpx 32rpx 32rpx 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 6rpx 6rpx 0 0 #ffb84d;
  position: relative;
  overflow: visible;
}

.session:active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 3rpx 3rpx 0 0 #ffb84d;
}

.session .title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3d2914;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
  margin-bottom: 18rpx;
  letter-spacing: -0.2rpx;
}

.session .meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

/* 消息数 chip */
.session .msg-count {
  display: inline-flex;
  align-items: center;
  background: #ff8a65;
  color: #ffffff;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.3rpx;
  border: 1.5px solid #3d2914;
  box-shadow: 3rpx 3rpx 0 0 #3d2914;
}

.session .ts {
  color: #8b5a2b;
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 600;
}

.session .hint {
  position: absolute;
  top: 14rpx;
  right: 20rpx;
  font-size: 20rpx;
  color: #a89887;
  font-weight: 600;
}
