.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f7f7f7;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.loading {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 28rpx;
  padding: 120rpx 0;
}

.error {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  gap: 24rpx;
}

.error text {
  color: #dc2626;
  font-size: 28rpx;
  text-align: center;
}

.empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 28rpx;
  padding: 120rpx 0;
}

/* CP-7-B 真接 round 4: session 列表卡片样式 */
.session-list {
  padding: 24rpx 24rpx 100rpx;
}

.session {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  position: relative;
}

.session:active {
  transform: scale(0.98);
  background: #f9fafb;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.session .title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
  margin-bottom: 16rpx;
}

.session .meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.session .msg-count {
  display: inline-flex;
  align-items: center;
  background: #eef2ff;
  color: #4f46e5;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.session .ts {
  color: #d1d5db;
  margin-left: auto;
  font-size: 22rpx;
}

.session .hint {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  font-size: 20rpx;
  color: #d1d5db;
}
