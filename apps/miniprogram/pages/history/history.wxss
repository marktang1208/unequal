/* CP-7-B round 6: B 温暖调 — 米色 + 粉茶 / 薄荷绿 chip / 粉茶装饰条
 * Design token：
 *   背景米色      #faf5ed
 *   卡片象牙白    #ffffff
 *   暖边框        #f0e6d2
 *   深棕主文      #4a2c2a
 *   中棕次文      #8a6850
 *   粉茶强调      #c4847a (装饰条 gradient end)
 *   驼金强调      #d4a574 (装饰条 gradient start)
 *   薄荷绿 chip   #a8c8a0
 *   柔金提示      #c4a890
 */

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #faf5ed;
  box-sizing: border-box;
  position: relative;
}

/* 右上角柔光：暖驼色 */
.page::before {
  content: "";
  position: fixed;
  top: -200rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.15) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  background: transparent;
  border-bottom: none;
  position: relative;
  z-index: 1;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a2c2a;
  letter-spacing: -0.5rpx;
}

.loading,
.empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a6850;
  font-size: 28rpx;
  padding: 120rpx 0;
  position: relative;
  z-index: 1;
}

.error {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.error text {
  color: #b91c1c;
  font-size: 28rpx;
  text-align: center;
}

/* 列表区 */
.session-list {
  padding: 16rpx 24rpx 120rpx;
  position: relative;
  z-index: 1;
}

/* 温暖卡片 */
.session {
  background: #ffffff;
  border: 1rpx solid #f0e6d2;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow:
    0 2rpx 12rpx rgba(155, 100, 80, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  position: relative;
  overflow: hidden;
}

/* 卡片左侧装饰条：驼金→粉茶渐变 */
.session::before {
  content: "";
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 4rpx;
  background: linear-gradient(180deg, #d4a574 0%, #c4847a 100%);
  border-radius: 0 4rpx 4rpx 0;
  opacity: 0.85;
}

.session:active {
  transform: scale(0.98);
  background: #fdf9f1;
  box-shadow:
    0 1rpx 4rpx rgba(155, 100, 80, 0.10),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

/* 卡片标题 */
.session .title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a2c2a;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
  margin-bottom: 18rpx;
  letter-spacing: -0.2rpx;
}

/* 元信息行 */
.session .meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

/* 消息数 chip — 薄荷绿 */
.session .msg-count {
  display: inline-flex;
  align-items: center;
  background: #a8c8a0;
  color: #ffffff;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
  box-shadow: 0 2rpx 6rpx rgba(168, 200, 160, 0.4);
}

/* 时间戳 — 中棕 */
.session .ts {
  color: #8a6850;
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 500;
}

/* 长按提示 — 柔金 */
.session .hint {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  font-size: 20rpx;
  color: #c4a890;
  font-weight: 500;
}
