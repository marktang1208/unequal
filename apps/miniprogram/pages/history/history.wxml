<view class="page">
  <view class="header">
    <text class="header-title">历史问答</text>
    <button class="btn-clear" bindtap="onClear" wx:if="{{entries.length > 0}}">清空</button>
  </view>

  <view class="empty" wx:if="{{entries.length === 0}}">
    <text>暂无历史问答</text>
  </view>

  <view class="entry-list" wx:else>
    <view
      class="entry"
      wx:for="{{entries}}"
      wx:key="timestamp"
      data-q="{{item.q}}"
      bindtap="onAskAgain"
    >
      <view class="q">{{item.q}}</view>
      <view class="meta">
        <text class="cite-count">{{item.citations.length}} 个来源</text>
        <text class="cached" wx:if="{{item.cached}}">已缓存</text>
        <text class="ts">{{item.timestamp}}</text>
      </view>
    </view>
  </view>
</view>
