<view class="page">
  <view class="header">
    <text class="header-title">历史问答</text>
  </view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中…</text>
  </view>

  <view class="error" wx:elif="{{error}}">
    <text>{{error}}</text>
    <button bindtap="refresh">重试</button>
  </view>

  <view class="empty" wx:elif="{{sessions.length === 0}}">
    <text>暂无历史问答</text>
  </view>

  <view class="session-list" wx:else>
    <view
      class="session"
      wx:for="{{sessions}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-title="{{item.title}}"
      bindtap="onTapSession"
      bindlongpress="onLongPressSession"
      hover-class="session-hover"
      hover-stay-time="50"
    >
      <view class="hint">长按操作</view>
      <view class="title">{{item.title || '未命名会话'}}</view>
      <view class="meta">
        <text class="msg-count">{{item.messageCount}} 条</text>
        <text class="ts">{{item.updatedAtText}}</text>
      </view>
    </view>
  </view>
</view>