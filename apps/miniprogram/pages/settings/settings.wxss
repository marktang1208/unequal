/* M7-D settings page styles */

.container {
  padding: 32rpx;
  padding-bottom: 200rpx;
}

.loading,
.error,
.empty {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #666;
  font-size: 28rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.error {
  color: #dc2626;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 28rpx;
}

.row:last-child {
  border-bottom: none;
}

.row-label {
  color: #666;
  flex-shrink: 0;
}

.row-value {
  color: #333;
  text-align: right;
  word-break: break-all;
}

.row-value.mono {
  font-family: "SF Mono", "Monaco", "Consolas", monospace;
  font-size: 24rpx;
  max-width: 60%;
}

.isolation-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #555;
  padding: 24rpx 0;
}

.logout-btn {
  background: #dc2626;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin: 16rpx 0;
}

.logout-btn::after {
  border: none;
}
