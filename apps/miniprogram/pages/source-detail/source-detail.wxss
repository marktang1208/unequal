.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 32rpx 24rpx;
  background: #f7f7f7;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.4;
}

.trust-badge {
  align-self: flex-start;
  font-size: 22rpx;
  color: #1d4ed8;
  background: #dbeafe;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.meta {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 8rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  color: #6b7280;
  word-break: break-all;
}

.meta-label {
  flex-shrink: 0;
  color: #9ca3af;
}

.meta-value {
  flex: 1;
  font-family: ui-monospace, "SF Mono", Menlo, monospace;
  color: #4b5563;
}

.content {
  flex: 1;
  padding: 32rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.content .placeholder {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.7;
}

.actions {
  display: flex;
  justify-content: stretch;
}

.btn-primary {
  flex: 1;
  background: #2563eb;
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 16rpx;
  margin: 0;
}

.btn-primary::after {
  border: none;
}
