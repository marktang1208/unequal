/* CP-7-B round 8: 06 童心日历 — chat 页 px 单位修描边
 */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff9e6;
  box-sizing: border-box;
  position: relative;
}

.message-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx 0;
  overflow-y: auto;
  position: relative;
  z-index: 1;
}

.loading {
  align-self: center;
  padding: 16rpx 32rpx;
  color: #8b5a2b;
  font-size: 24rpx;
  font-weight: 600;
  background: #ffffff;
  border: 2px solid #3d2914;
  border-radius: 100rpx;
  margin: 16rpx;
  box-shadow: 4rpx 4rpx 0 0 #ffb84d;
}

.error-bar {
  background: #fff0e0;
  color: #d63a1a;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border-top: 2px dashed #3d2914;
  border-bottom: 2px dashed #3d2914;
  position: relative;
  z-index: 1;
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 24rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff9e6;
  border-top: 2px dashed #3d2914;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

/* 输入框 */
.input-bar .input {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  padding: 18rpx 24rpx;
  background: #ffffff;
  border: 2px solid #3d2914;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #3d2914;
  box-sizing: border-box;
  font-weight: 500;
}

/* 提问按钮 — 启用态：暖橙 + 粗描边 + 偏移阴影 */
.input-bar .btn-send {
  flex-shrink: 0;
  margin: 0;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 76rpx;
  background: #ff8a65;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  border: 2px solid #3d2914;
  border-radius: 24rpx;
  box-shadow: 6rpx 6rpx 0 0 #3d2914;
  letter-spacing: 1rpx;
}

.input-bar .btn-send::after {
  border: none;
}

.input-bar .btn-send:active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 3rpx 3rpx 0 0 #3d2914;
}

/* 禁用态：暖橙降饱和度 + 阴影保留（保持视觉一致性） */
.input-bar .btn-send[disabled] {
  background: #ffd0b8;
  color: #ffffff;
  border-color: #3d2914;
  box-shadow: 4rpx 4rpx 0 0 #a89887;
}
