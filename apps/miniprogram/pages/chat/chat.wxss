/* CP-7-B round 6: 问答 tab 同步 B 温暖调
 * 与 history.wxss 共享 design token：
 *   背景米色 #faf5ed
 *   卡片象牙白 #ffffff
 *   暖边框 #f0e6d2
 *   user 气泡：粉茶 #c4847a → 驼金 #d4a574 渐变
 *   assistant 气泡：象牙白底 + 暖边
 *   输入区：浅米底 + 暖边
 *   提问按钮：粉茶 / 禁用驼茶
 */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #faf5ed;
  box-sizing: border-box;
  position: relative;
}

/* 右上角柔光：暖驼色（与 history 一致） */
.chat-page::before {
  content: "";
  position: fixed;
  top: -200rpx;
  right: -200rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.15) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.message-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 20rpx 0;
  overflow-y: auto;
  position: relative;
  z-index: 1;
}

.loading {
  align-self: center;
  padding: 16rpx 32rpx;
  color: #8a6850;
  font-size: 24rpx;
  background: #ffffff;
  border: 1rpx solid #f0e6d2;
  border-radius: 16rpx;
  margin: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(155, 100, 80, 0.06);
}

.error-bar {
  background: #fef0eb;
  color: #9b3a2e;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  text-align: center;
  border-top: 1rpx solid #f0d6c8;
  position: relative;
  z-index: 1;
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0e6d2;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.input-bar .input {
  flex: 1;
  min-height: 64rpx;
  max-height: 200rpx;
  padding: 16rpx 22rpx;
  background: #faf5ed;
  border: 1rpx solid #f0e6d2;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #4a2c2a;
  box-sizing: border-box;
}

/* 提问按钮：粉茶 → 驼金渐变 */
.input-bar .btn-send {
  flex-shrink: 0;
  margin: 0;
  padding: 0 36rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #c4847a 0%, #d4a574 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(196, 132, 122, 0.3);
  letter-spacing: 0.5rpx;
}

.input-bar .btn-send::after {
  border: none;
}

.input-bar .btn-send[disabled] {
  background: #e8d5c4;
  color: #ffffff;
  box-shadow: none;
}
