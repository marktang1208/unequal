/* CP-7-B round 8: 06 童心日历 — chat 页 px 单位修描边
 */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fff9e6;
  box-sizing: border-box;
  position: relative;
}

.message-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx 0 24rpx;
  overflow-y: auto;
  /* 不裁右下角的气泡 box-shadow */
  overflow-x: visible;
  position: relative;
  z-index: 1;
}

.loading {
  align-self: center;
  padding: 16rpx 32rpx;
  color: #8b5a2b;
  font-size: 24rpx;
  font-weight: 600;
  background: #ffffff;
  border: 2px solid #3d2914;
  border-radius: 100rpx;
  margin: 16rpx;
  box-shadow: 4rpx 4rpx 0 0 #ffb84d;
}

.error-bar {
  background: #fff0e0;
  color: #d63a1a;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  border-top: 2px dashed #3d2914;
  border-bottom: 2px dashed #3d2914;
  position: relative;
  z-index: 1;
}

/* 输入区 */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  padding: 24rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff9e6;
  border-top: 2px dashed #3d2914;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

/* 输入框 */
.input-bar .input {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  padding: 18rpx 24rpx;
  background: #ffffff;
  border: 2px solid #3d2914;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #3d2914;
  box-sizing: border-box;
  font-weight: 500;
}

/* M7-B: source type picker（多选 chip，水平滚动） */
.source-picker {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: #fff9e6;
  border-top: 2px dashed #3d2914;
  white-space: nowrap;
  position: relative;
  z-index: 1;
}

.source-picker .chip {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  padding: 8rpx 24rpx;
  background: #ffffff;
  color: #3d2914;
  font-size: 24rpx;
  font-weight: 600;
  border: 2px solid #3d2914;
  border-radius: 100rpx;
  letter-spacing: 1rpx;
  /* offset shadow 让选中态可见 */
  box-shadow: 2rpx 2rpx 0 0 #a89887;
}

.source-picker .chip--active {
  background: #ff8a65;
  color: #ffffff;
  border-color: #3d2914;
  box-shadow: 3rpx 3rpx 0 0 #3d2914;
}

.source-picker .chip:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 0rpx 0rpx 0 0 #3d2914;
}

/* 头部左侧：新会话入口（+ 号，镜像 .settings-fab 风格） */
.new-session-fab {
  position: fixed;
  top: 24rpx;
  left: 24rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.new-session-fab:active {
  transform: scale(0.92);
}

.new-session-fab-icon {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  line-height: 1;
  margin-top: -4rpx; /* 视觉居中微调 */
}

/* M7-D: 右上角设置入口 FAB */
.settings-fab {
  position: fixed;
  top: 24rpx;
  right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.settings-fab:active {
  transform: scale(0.92);
}

.settings-fab-icon {
  font-size: 40rpx;
  color: #333;
}
