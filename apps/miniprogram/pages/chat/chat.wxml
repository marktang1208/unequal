<view class="chat-page">
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{lastMsgId}}"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{item.id}}"
    >
      <message-bubble
        role="{{item.role}}"
        text="{{item.text}}"
        cached="{{item.cached}}"
        citations="{{item.citations}}"
        segments="{{item.segments}}"
      />
    </view>
    <view class="loading" wx:if="{{submitting}}">
      <text>正在思考…</text>
    </view>
  </scroll-view>

  <view class="error-bar" wx:if="{{error}}">
    <text>{{error}}</text>
  </view>

  <!-- M7-B: source type picker（多选 chip；选空 = 不过滤） -->
  <scroll-view class="source-picker" scroll-x enhanced show-scrollbar="{{false}}">
    <view
      wx:for="{{availableSourceTypes}}"
      wx:key="value"
      class="chip {{selectedSourceTypes.indexOf(item.value) >= 0 ? 'chip--active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onToggleSourceType"
    >{{item.label}}</view>
  </scroll-view>

  <view class="input-bar">
    <textarea
      class="input"
      value="{{q}}"
      bindinput="onQInput"
      placeholder="请输入育儿问题…"
      auto-height
      maxlength="500"
      confirm-type="send"
      bindconfirm="onSubmit"
    />
    <button
      class="btn-send"
      bindtap="onSubmit"
      disabled="{{submitting || !q}}"
    >提问</button>
  </view>

  <!-- M7-D: 设置入口（右上角悬浮） -->
  <view class="settings-fab" bindtap="onTapSettings">
    <text class="settings-fab-icon">⚙</text>
  </view>
</view>
