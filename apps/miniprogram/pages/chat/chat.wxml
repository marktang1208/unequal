<view class="chat-page">
  <!-- 头部左侧空出 (P11.2: + 号挪到右上避免遮消息) -->

  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{lastMsgId}}"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view
      wx:for="{{messages}}"
      wx:key="id"
      id="msg-{{item.id}}"
    >
      <message-bubble
        role="{{item.role}}"
        text="{{item.text}}"
        cached="{{item.cached}}"
        citations="{{item.citations}}"
        segments="{{item.segments}}"
      />
    </view>
    <view class="loading" wx:if="{{submitting}}">
      <text>正在思考…</text>
    </view>
  </scroll-view>

  <view class="error-bar" wx:if="{{error}}">
    <text>{{error}}</text>
  </view>

  <view class="input-bar">
    <textarea
      class="input"
      value="{{q}}"
      bindinput="onQInput"
      placeholder="请输入育儿问题…"
      auto-height
      maxlength="500"
      confirm-type="send"
      bindconfirm="onSubmit"
    />
  </view>

  <!-- M7-D: 设置入口（右上角悬浮） -->
  <view class="settings-fab" bindtap="onTapSettings">
    <text class="settings-fab-icon">⚙</text>
  </view>

  <!-- P11: 信息源筛选入口（⚙ 下方，🔍 + 数字徽章显示已选数） -->
  <view class="source-filter-fab" bindtap="onOpenSourceFilter">
    <text class="source-filter-fab-icon">🔍</text>
    <view class="filter-badge" wx:if="{{selectedSourceTypes.length > 0}}">{{selectedSourceTypes.length}}</view>
  </view>

  <!-- P11.2: 新会话入口（+ 号，挪到右上跟 ⚙/🔍 垂直排 3 列，避免遮消息） -->
  <view class="new-session-fab" bindtap="onTapNewSession">
    <text class="new-session-fab-icon">+</text>
  </view>

  <!-- P11: 信息源筛选 popup 弹层（半屏 + mask） -->
  <view
    class="source-popup-mask"
    wx:if="{{sourceFilterOpen}}"
    bindtap="onCloseSourceFilter"
  ></view>
  <view class="source-popup {{sourceFilterOpen ? 'source-popup--open' : ''}}">
    <view class="source-popup-header">
      <text class="source-popup-title">信息来源筛选</text>
      <view class="source-popup-close" bindtap="onCloseSourceFilter">×</view>
    </view>
    <view class="source-popup-body">
      <view
        wx:for="{{availableSourceTypes}}"
        wx:key="value"
        wx:for-item="src"
        class="source-popup-row {{activeMap[src.value] ? 'source-popup-row--active' : ''}}"
        hover-class="source-popup-row--hover"
        hover-stay-time="100"
        data-value="{{src.value}}"
        bindtap="onToggleSourceTypeInPopup"
      >
        <view class="source-popup-checkbox">{{activeMap[src.value] ? '✓' : ''}}</view>
        <text class="source-popup-label">{{src.label}}</text>
      </view>
    </view>
    <view class="source-popup-footer">
      <view class="source-popup-btn" bindtap="onResetSourceFilter">全部（默认）</view>
    </view>
  </view>
</view>
