{
  "name": "api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vitest",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy:readiness": "tsx scripts/deploy-readiness.ts",
    "deploy:build": "tsx scripts/deploy-build.ts",
    "deploy:collections": "tsx scripts/deploy-collections.ts",
    "deploy:indexes": "tsx scripts/deploy-indexes.ts",
    "deploy": "tsx scripts/deploy/index.ts",
    "deploy:push": "tsx scripts/deploy/index.ts push",
    "deploy:clean": "tsx scripts/deploy/index.ts clean",
    "deploy:status": "tsx scripts/deploy/index.ts status",
    "deploy:rotate-kek": "tsx scripts/deploy/index.ts rotate-kek",
    "setup:keychain-secrets": "bash scripts/setup-keychain-secrets.sh",
    "migrate:schema-ids": "tsx scripts/migrate-schema-ids.ts"
  },
  "dependencies": {
    "@cloudbase/node-sdk": "^3.18.1",
    "@unequal/shared": "workspace:*",
    "hono": "^4.5.0",
    "jose": "^4.15.9",
    "mammoth": "^1.12.0",
    "pdf-parse": "1.1.1",
    "ulid": "^3.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "cheerio": "1.0.0",
    "esbuild": "^0.21.5",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
