{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "version": "2.0",
  "envId": "unequal-d4ggf7rwg82e0900b",
  "functionRoot": "functions",
  "functions": [
    {
      "name": "api-router",
      "type": "Event",
      "runtime": "Nodejs20.19",
      "handler": "index.main",
      "timeout": 30,
      "memorySize": 256,
      "installDependency": true,
      "envVariables": {
        "ENVIRONMENT": "production",
        "ALLOWED_ORIGIN": "*",
        "MINIMAX_BASE_URL": "https://api.minimax.chat/v1",
        "DEFAULT_USER_ID": "01H0000000000000000000000",
        "LOGIN_MAX_ATTEMPTS": "5",
        "LOGIN_WINDOW_MS": "900000",
        "KEK_CURRENT_VERSION": "1",
        "NLI_PROVIDER": "http",
        "SILICONFLOW_BASE_URL": "https://api.siliconflow.cn/v1",
        "NLI_MODEL": "Qwen/Qwen2.5-7B-Instruct",
        "NLI_TIMEOUT_MS": "15000",
        "NLI_RETRY_COUNT": "1"
      }
    }
  ]
}