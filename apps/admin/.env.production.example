# CP-6: CloudBase 部署后 admin 需要的环境变量
# 复制为 .env.production 后填实际值
# 实际值在 CloudBase 控制台 → 云函数 → 配置 → 环境变量 也能配

# CloudBase HTTP 触发器 base URL
# 格式: https://<appid>.<region>.app.tcloudbase.com
# 其中 <region> 是创建环境时选的（如 ap-shanghai / ap-guangzhou）
VITE_API_BASE_URL=https://<appid>.<region>.app.tcloudbase.com

# Admin 静态托管域名（如果用了自定义域名，否则留空走默认）
# VITE_PUBLIC_BASE_URL=https://admin.example.com