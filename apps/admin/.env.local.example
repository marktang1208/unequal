# CloudBase admin 测试页配置（CP-6）
# 用法：cp .env.local.example .env.local，填 VITE_TCB_ENV_ID 后重启 pnpm dev
#
# js-sdk 1.8.x 是用户态 SDK（不支持 secretId/secretKey，那是 node-sdk 的）
# 这里用匿名登录调公开 endpoint（/api-health），env ID 是唯一需要的
# 调需要 admin auth 的 endpoint 时，需走 CF Pages Functions proxy

VITE_TCB_ENV_ID=unequal-d4ggf7rwg82e0900b
